<UserControl x:Class="OnAirCut.RenderServer.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:OnAirCut.RenderServer.ViewModels"
             xmlns:converters="clr-namespace:OnAirCut.RenderServer.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:HistoryViewModel}">

    <UserControl.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
    </UserControl.Resources>

    <DockPanel Margin="16">
        <!-- Search Bar -->
        <materialDesign:Card DockPanel.Dock="Top" Margin="0,0,0,12" Padding="16">
            <WrapPanel>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Search title, job ID, source..."
                         materialDesign:TextFieldAssist.HasLeadingIcon="True"
                         materialDesign:TextFieldAssist.LeadingIcon="Magnify"
                         Width="250" Margin="0,0,12,0" VerticalAlignment="Center"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                <DatePicker SelectedDate="{Binding DateFrom}"
                            materialDesign:HintAssist.Hint="From date"
                            Width="140" Margin="0,0,8,0" VerticalAlignment="Center"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" />

                <DatePicker SelectedDate="{Binding DateTo}"
                            materialDesign:HintAssist.Hint="To date"
                            Width="140" Margin="0,0,12,0" VerticalAlignment="Center"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" />

                <ComboBox ItemsSource="{Binding StatusOptions}"
                          SelectedItem="{Binding SelectedStatus}"
                          materialDesign:HintAssist.Hint="Status"
                          Width="120" Margin="0,0,12,0" VerticalAlignment="Center"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" />

                <Button Command="{Binding SearchCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="0,0,8,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Magnify" VerticalAlignment="Center" />
                        <TextBlock Text="Search" Margin="4,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Command="{Binding ClearFiltersCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,0,8,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FilterRemove" VerticalAlignment="Center" />
                        <TextBlock Text="Clear" Margin="4,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Command="{Binding ExportCsvCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileExport" VerticalAlignment="Center" />
                        <TextBlock Text="Export CSV" Margin="4,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <TextBlock VerticalAlignment="Center" Margin="16,0,0,0" Opacity="0.6">
                    <Run Text="Results: " />
                    <Run Text="{Binding TotalCount}" />
                </TextBlock>
            </WrapPanel>
        </materialDesign:Card>

        <!-- Results DataGrid -->
        <DataGrid ItemsSource="{Binding Stories}" AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserSortColumns="True"
                  CanUserResizeColumns="True" SelectionMode="Single"
                  materialDesign:DataGridAssist.CellPadding="12 8"
                  materialDesign:DataGridAssist.ColumnHeaderPadding="12 8"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open Folder"
                              Command="{Binding OpenOutputFolderCommand}"
                              CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=SelectedItem}">
                        <MenuItem.Icon>
                            <materialDesign:PackIcon Kind="FolderOpen" />
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Job ID" Binding="{Binding JobId}" Width="180" />
                <DataGridTextColumn Header="Title" Binding="{Binding TitleNormalized}" Width="220" />
                <DataGridTextColumn Header="Source" Binding="{Binding SourceName}" Width="120" />
                <DataGridTemplateColumn Header="Status" Width="120" SortMemberPath="Status">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <materialDesign:Chip Content="{Binding Status}" IconBackground="Transparent"
                                                 Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                                 Foreground="White" FontSize="11" Padding="8,2" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Duration" Width="80"
                                    Binding="{Binding DurationSeconds, StringFormat={}{0:F1}s}" />
                <DataGridTextColumn Header="OCR %" Width="70"
                                    Binding="{Binding OcrConfidence, StringFormat={}{0:F0}%}" />
                <DataGridTextColumn Header="Submitted" Width="140"
                                    Binding="{Binding SubmittedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" />
                <DataGridTextColumn Header="Processed" Width="140"
                                    Binding="{Binding ProcessedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" />
                <DataGridTextColumn Header="Output" Binding="{Binding OutputFolderPath}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
