<UserControl x:Class="OnAirCut.RenderServer.Views.JobDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:OnAirCut.RenderServer.ViewModels"
             xmlns:converters="clr-namespace:OnAirCut.RenderServer.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:JobDetailViewModel}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel>
            <!-- Job Metadata Card -->
            <materialDesign:Card Margin="0,0,0,16" Padding="20">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <materialDesign:PackIcon Kind="InformationOutline" Width="24" Height="24"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" />
                        <TextBlock Text="Job Details" FontSize="18" FontWeight="Medium"
                                   VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                                    HorizontalAlignment="Right">
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding RetryCommand}" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Replay" VerticalAlignment="Center" />
                                    <TextBlock Text="Retry" Margin="4,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding OpenOutputFolderCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FolderOpen" VerticalAlignment="Center" />
                                    <TextBlock Text="Open Output" Margin="4,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding OpenRawClipCommand}" Margin="8,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FileVideo" VerticalAlignment="Center" />
                                    <TextBlock Text="Open Raw" Margin="4,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </DockPanel>

                    <UniformGrid Columns="3" Margin="0,8">
                        <StackPanel Margin="0,4">
                            <TextBlock Text="Job ID" Opacity="0.6" FontSize="12" />
                            <TextBlock Text="{Binding JobId}" FontWeight="Medium" FontSize="14" />
                        </StackPanel>
                        <StackPanel Margin="0,4">
                            <TextBlock Text="Status" Opacity="0.6" FontSize="12" />
                            <TextBlock Text="{Binding Status}" FontWeight="Medium" FontSize="14" />
                        </StackPanel>
                        <StackPanel Margin="0,4">
                            <TextBlock Text="Source" Opacity="0.6" FontSize="12" />
                            <TextBlock Text="{Binding SourceName}" FontWeight="Medium" FontSize="14" />
                        </StackPanel>
                        <StackPanel Margin="0,4">
                            <TextBlock Text="Title (Raw)" Opacity="0.6" FontSize="12" />
                            <TextBlock Text="{Binding TitleRaw}" FontWeight="Medium" FontSize="14"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Margin="0,4">
                            <TextBlock Text="Title (Normalized)" Opacity="0.6" FontSize="12" />
                            <TextBlock Text="{Binding TitleNormalized}" FontWeight="Medium" FontSize="14" />
                        </StackPanel>
                        <StackPanel Margin="0,4">
                            <TextBlock Text="Duration" Opacity="0.6" FontSize="12" />
                            <TextBlock Text="{Binding DurationText}" FontWeight="Medium" FontSize="14" />
                        </StackPanel>
                        <StackPanel Margin="0,4">
                            <TextBlock Text="AdSet" Opacity="0.6" FontSize="12" />
                            <TextBlock Text="{Binding AdSetName}" FontWeight="Medium" FontSize="14" />
                        </StackPanel>
                        <StackPanel Margin="0,4"
                                    Visibility="{Binding HasAdConfig, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Ad Configuration" Opacity="0.6" FontSize="12" />
                            <Border Background="#1A1A2E" CornerRadius="4" Padding="8" Margin="0,4,0,0">
                                <TextBlock Text="{Binding AdConfigSummary}" FontFamily="Consolas"
                                           FontSize="11" Foreground="#DDD" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,4">
                            <TextBlock Text="Submitted" Opacity="0.6" FontSize="12" />
                            <TextBlock Text="{Binding SubmittedAt}" FontWeight="Medium" FontSize="14" />
                        </StackPanel>
                        <StackPanel Margin="0,4">
                            <TextBlock Text="Processed" Opacity="0.6" FontSize="12" />
                            <TextBlock Text="{Binding ProcessedAt}" FontWeight="Medium" FontSize="14" />
                        </StackPanel>
                    </UniformGrid>

                    <!-- Error Message -->
                    <Border Background="#3FC62828" CornerRadius="4" Padding="12" Margin="0,8,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AlertCircle" Foreground="#EF5350"
                                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF5350"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </materialDesign:Card>

            <!-- Processing Timeline -->
            <materialDesign:Card Margin="0,0,0,16" Padding="20">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <materialDesign:PackIcon Kind="Timeline" Width="22" Height="22"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" />
                        <TextBlock Text="Processing Steps" FontSize="16" FontWeight="Medium"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding StepLogs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                                        BorderThickness="0,0,0,1" Padding="8,6" Margin="0,2">
                                    <DockPanel>
                                        <materialDesign:PackIcon Kind="CheckCircleOutline" Width="16" Height="16"
                                                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                        <TextBlock Text="{Binding Step}" FontWeight="Medium" Width="120"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Status}" Width="80" Opacity="0.7"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Duration}" Width="80" FontFamily="Consolas"
                                                   Opacity="0.6" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Message}" Opacity="0.5"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </materialDesign:Card>

            <!-- OCR Results -->
            <materialDesign:Card Margin="0,0,0,16" Padding="20">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <materialDesign:PackIcon Kind="TextRecognition" Width="22" Height="22"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" />
                        <TextBlock Text="OCR Results" FontSize="16" FontWeight="Medium"
                                   VerticalAlignment="Center" />
                        <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                   VerticalAlignment="Center" Opacity="0.7">
                            <Run Text="Confidence: " />
                            <Run Text="{Binding OcrConfidence, StringFormat={}{0:F1}%}" />
                        </TextBlock>
                    </DockPanel>
                    <DataGrid ItemsSource="{Binding OcrResults}" AutoGenerateColumns="False"
                              IsReadOnly="True" MaxHeight="200"
                              materialDesign:DataGridAssist.CellPadding="8 4">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Frame" Binding="{Binding FrameIndex}" Width="60" />
                            <DataGridTextColumn Header="Text" Binding="{Binding RawText}" Width="*" />
                            <DataGridTextColumn Header="Confidence" Binding="{Binding Confidence, StringFormat={}{0:F1}%}" Width="100" />
                            <DataGridTextColumn Header="Profile" Binding="{Binding ProfileUsed}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </materialDesign:Card>

            <!-- Frame Thumbnails -->
            <materialDesign:Card Margin="0,0,0,16" Padding="20">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <materialDesign:PackIcon Kind="ImageMultiple" Width="22" Height="22"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" />
                        <TextBlock Text="Frame Thumbnails" FontSize="16" FontWeight="Medium"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding FrameThumbnails}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="4" BorderBrush="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                                            BorderThickness="1" CornerRadius="4">
                                        <Image Source="{Binding}" Width="160" Height="90"
                                               Stretch="UniformToFill" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>
