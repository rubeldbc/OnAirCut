<UserControl x:Class="OnAirCut.RenderServer.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:OnAirCut.RenderServer.ViewModels"
             xmlns:converters="clr-namespace:OnAirCut.RenderServer.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Style="{StaticResource MaterialDesignFilledTabControl}">

            <!-- General Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Cog" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="General" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left" Margin="16">

                        <TextBlock Text="API SETTINGS" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <UniformGrid Columns="2" Margin="0,0,0,16">
                            <StackPanel Margin="0,0,8,0">
                                <TextBox Text="{Binding ApiPort, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="API Port"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                                <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                              IsChecked="{Binding ApiEnabled}" Margin="0,0,8,0" />
                                <TextBlock Text="API Enabled" VerticalAlignment="Center" />
                            </StackPanel>
                        </UniformGrid>

                        <Separator Margin="0,0,0,16" />

                        <!-- Dependencies Section -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="Download" Width="20" Height="20"
                                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Dependencies" FontSize="16" FontWeight="Medium"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <Button Command="{Binding CheckDependenciesCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                materialDesign:ButtonAssist.CornerRadius="4"
                                Content="Check All" Margin="0,0,0,8" HorizontalAlignment="Left" />

                        <Button Command="{Binding DownloadAllMissingCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                materialDesign:ButtonAssist.CornerRadius="4"
                                Background="#66BB6A" Foreground="White"
                                Content="Download All Missing" Margin="0,0,0,12" HorizontalAlignment="Left" />

                        <ItemsControl ItemsSource="{Binding Dependencies}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <materialDesign:Card Padding="12" Margin="0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Name + Status -->
                                            <StackPanel Grid.Column="0" Grid.Row="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="13" />
                                                    <TextBlock Text="{Binding Size}" FontSize="11" Opacity="0.5"
                                                               Margin="8,0,0,0" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" FontSize="10" Opacity="0.6" />
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <!-- Green check or Red X -->
                                                    <materialDesign:PackIcon Width="14" Height="14"
                                                                             VerticalAlignment="Center" Margin="0,0,4,0">
                                                        <materialDesign:PackIcon.Style>
                                                            <Style TargetType="materialDesign:PackIcon">
                                                                <Setter Property="Kind" Value="CloseCircle" />
                                                                <Setter Property="Foreground" Value="#EF5350" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                                        <Setter Property="Kind" Value="CheckCircle" />
                                                                        <Setter Property="Foreground" Value="#66BB6A" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </materialDesign:PackIcon.Style>
                                                    </materialDesign:PackIcon>
                                                    <TextBlock Text="{Binding Status}" FontSize="11"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Download Button -->
                                            <Button Grid.Column="1" Grid.Row="0"
                                                    Command="{Binding DataContext.DownloadDependencyCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    materialDesign:ButtonAssist.CornerRadius="4"
                                                    Content="Download" Padding="8,4" FontSize="11"
                                                    Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />

                                            <!-- Progress Bar (when downloading) -->
                                            <Grid Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                                                  Margin="0,6,0,0"
                                                  Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibility}}">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <ProgressBar Grid.Row="0" Value="{Binding DownloadProgress}"
                                                             Minimum="0" Maximum="100" Height="6" />
                                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding DownloadProgress, StringFormat='{}{0:F0}%'}"
                                                               FontSize="10" />
                                                    <TextBlock Text="{Binding DownloadSpeed}" FontSize="10"
                                                               Margin="12,0,0,0" Opacity="0.6" />
                                                    <TextBlock Text="{Binding Eta}" FontSize="10"
                                                               Margin="12,0,0,0" Opacity="0.6" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </materialDesign:Card>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Shared Folder Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FolderNetwork" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Shared Folder" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left" Margin="16">

                        <TextBlock Text="SHARED FOLDER PATH" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <DockPanel Margin="0,0,0,16">
                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding BrowseSharedFolderCommand}"
                                    Content="Browse" Margin="8,0,0,0" VerticalAlignment="Center" />
                            <TextBox Text="{Binding SharedFolderPath, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Shared folder path"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        </DockPanel>

                        <!-- Create Folder Structure -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Button Command="{Binding CreateFolderStructureCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="4"
                                    Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FolderPlus" Margin="0,0,8,0"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Create Folder Structure" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ValidateSharedFolderCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="4">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FolderCheck" Margin="0,0,8,0"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Validate" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Validation Status -->
                        <TextBlock Text="FOLDER VALIDATION" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding FolderValidationItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <materialDesign:PackIcon Width="18" Height="18"
                                                                 VerticalAlignment="Center" Margin="0,0,8,0">
                                            <materialDesign:PackIcon.Style>
                                                <Style TargetType="materialDesign:PackIcon">
                                                    <Setter Property="Kind" Value="CloseCircle" />
                                                    <Setter Property="Foreground" Value="#EF5350" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Exists}" Value="True">
                                                            <Setter Property="Kind" Value="CheckCircle" />
                                                            <Setter Property="Foreground" Value="#66BB6A" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:PackIcon.Style>
                                        </materialDesign:PackIcon>
                                        <TextBlock Text="{Binding FolderName}" VerticalAlignment="Center"
                                                   FontSize="13" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Rendering Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="MovieOpen" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Rendering" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel MaxWidth="700" HorizontalAlignment="Left" Margin="16">

                        <TextBlock Text="EXTERNAL TOOLS" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <DockPanel Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding BrowseFFmpegCommand}" Content="Browse"
                                    Margin="8,0,0,0" VerticalAlignment="Center" />
                            <TextBox Text="{Binding FfmpegPath, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="FFmpeg Path"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,16">
                            <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding BrowseFFprobeCommand}" Content="Browse"
                                    Margin="8,0,0,0" VerticalAlignment="Center" />
                            <TextBox Text="{Binding FfprobePath, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="FFprobe Path"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        </DockPanel>

                        <TextBlock Text="VIDEO ENCODING" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <UniformGrid Columns="2" Margin="0,0,0,12">
                            <StackPanel Margin="0,0,8,0">
                                <ComboBox ItemsSource="{Binding VideoCodecOptions}"
                                          SelectedItem="{Binding OutputVideoCodec}"
                                          materialDesign:HintAssist.Hint="Video Codec"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,0">
                                <ComboBox ItemsSource="{Binding PresetOptions}"
                                          SelectedItem="{Binding OutputVideoPreset}"
                                          materialDesign:HintAssist.Hint="Preset"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                            </StackPanel>
                        </UniformGrid>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Margin="0,0,0,4">
                                <Run Text="CRF: " /><Run Text="{Binding OutputVideoCRF}" FontWeight="Bold" />
                            </TextBlock>
                            <Slider Minimum="0" Maximum="51" Value="{Binding OutputVideoCRF}"
                                    TickFrequency="1" IsSnapToTickEnabled="True" />
                        </StackPanel>

                        <TextBlock Text="AUDIO ENCODING" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <UniformGrid Columns="2" Margin="0,0,0,12">
                            <StackPanel Margin="0,0,8,0">
                                <ComboBox ItemsSource="{Binding AudioCodecOptions}"
                                          SelectedItem="{Binding OutputAudioCodec}"
                                          materialDesign:HintAssist.Hint="Audio Codec"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,0">
                                <TextBox Text="{Binding OutputAudioBitrate, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Audio Bitrate"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                            </StackPanel>
                        </UniformGrid>

                        <TextBlock Text="CONCURRENT RENDERS" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <TextBox Text="{Binding MaxConcurrentRenders, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Max Concurrent Renders"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Width="200" HorizontalAlignment="Left" />

                        <!-- Test FFmpeg -->
                        <Button Command="{Binding TestFFmpegCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,16,0,0" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="MovieOpen" VerticalAlignment="Center" />
                                <TextBlock Text="Test FFmpeg" Margin="4,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- OCR Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="TextRecognition" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="OCR" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left" Margin="16">

                        <TextBlock Text="OCR ENGINE" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <DockPanel Margin="0,0,0,16">
                            <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding BrowseOcrEngineCommand}" Content="Browse"
                                    Margin="8,0,0,0" VerticalAlignment="Center" />
                            <TextBox Text="{Binding OcrEnginePath, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="OCR Engine (Tesseract Data) Path"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        </DockPanel>

                        <TextBlock Text="OCR SETTINGS" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <UniformGrid Columns="3" Margin="0,0,0,12">
                            <StackPanel Margin="0,0,8,0">
                                <TextBox Text="{Binding OcrLanguage, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="OCR Language"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                            </StackPanel>
                            <StackPanel Margin="8,0,8,0">
                                <TextBox Text="{Binding OcrMultiFrameCount, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Multi-frame Count"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,0">
                                <TextBox Text="{Binding FrameExtractionCount, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Frame Extraction Count"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                            </StackPanel>
                        </UniformGrid>

                        <!-- Test OCR -->
                        <Button Command="{Binding TestOcrCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="TextRecognition" VerticalAlignment="Center" />
                                <TextBlock Text="Test OCR" Margin="4,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Queue Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PlaylistPlay" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Queue" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left" Margin="16">

                        <TextBlock Text="POLLING" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <UniformGrid Columns="2" Margin="0,0,0,16">
                            <StackPanel Margin="0,0,8,0">
                                <TextBox Text="{Binding JobPollIntervalMs, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Poll Interval (ms)"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,0">
                                <TextBox Text="{Binding FileReadyCheckIntervalMs, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="File Ready Check Interval (ms)"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                            </StackPanel>
                        </UniformGrid>

                        <TextBlock Text="FILE STABILITY" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <TextBox Text="{Binding FileReadyStableSeconds, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="File Stable Seconds"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Width="200" HorizontalAlignment="Left" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Storage Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Database" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Storage" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left" Margin="16">

                        <TextBlock Text="DATABASE" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <DockPanel Margin="0,0,0,16">
                            <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding BrowseDatabaseCommand}" Content="Browse"
                                    Margin="8,0,0,0" VerticalAlignment="Center" />
                            <TextBox Text="{Binding LocalDatabasePath, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Database Path"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        </DockPanel>

                        <TextBlock Text="TEMP WORKING FOLDER" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <DockPanel Margin="0,0,0,16">
                            <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding BrowseTempFolderCommand}" Content="Browse"
                                    Margin="8,0,0,0" VerticalAlignment="Center" />
                            <TextBox Text="{Binding TempWorkingFolder, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Temp Working Folder (optional)"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        </DockPanel>

                        <TextBlock Text="CLEANUP" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <TextBox Text="{Binding CleanupWorkingFolderAfterDays, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Working Folder Retention (days)"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Width="300" HorizontalAlignment="Left" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Action Buttons (always visible at bottom) -->
        <Border Grid.Row="1" Padding="16,8"
                BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           Margin="0,0,16,0" FontSize="12"
                           Foreground="{DynamicResource SecondaryHueMidBrush}" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Button Command="{Binding ResetCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Restore" VerticalAlignment="Center" />
                            <TextBlock Text="Reset to Defaults" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SaveCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" />
                            <TextBlock Text="Save Settings" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
