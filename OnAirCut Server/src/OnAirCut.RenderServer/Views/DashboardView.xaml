<UserControl x:Class="OnAirCut.RenderServer.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:OnAirCut.RenderServer.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Row: Stat Cards -->
        <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,16">
            <!-- Pending -->
            <materialDesign:Card Margin="8" Padding="20" Background="#1565C0">
                <StackPanel>
                    <DockPanel>
                        <materialDesign:PackIcon Kind="TimerSand" Width="32" Height="32"
                                                 Foreground="White" DockPanel.Dock="Right" />
                        <TextBlock Text="Pending" FontSize="14" Foreground="#B0BEC5" />
                    </DockPanel>
                    <TextBlock Text="{Binding PendingCount}" FontSize="42" FontWeight="Bold"
                               Foreground="White" Margin="0,8,0,0" />
                </StackPanel>
            </materialDesign:Card>

            <!-- Active -->
            <materialDesign:Card Margin="8" Padding="20" Background="#F57F17">
                <StackPanel>
                    <DockPanel>
                        <materialDesign:PackIcon Kind="ProgressClock" Width="32" Height="32"
                                                 Foreground="White" DockPanel.Dock="Right" />
                        <TextBlock Text="Active" FontSize="14" Foreground="#FFF9C4" />
                    </DockPanel>
                    <TextBlock Text="{Binding ActiveCount}" FontSize="42" FontWeight="Bold"
                               Foreground="White" Margin="0,8,0,0" />
                </StackPanel>
            </materialDesign:Card>

            <!-- Completed -->
            <materialDesign:Card Margin="8" Padding="20" Background="#2E7D32">
                <StackPanel>
                    <DockPanel>
                        <materialDesign:PackIcon Kind="CheckCircle" Width="32" Height="32"
                                                 Foreground="White" DockPanel.Dock="Right" />
                        <TextBlock Text="Completed" FontSize="14" Foreground="#C8E6C9" />
                    </DockPanel>
                    <TextBlock Text="{Binding CompletedCount}" FontSize="42" FontWeight="Bold"
                               Foreground="White" Margin="0,8,0,0" />
                </StackPanel>
            </materialDesign:Card>

            <!-- Failed -->
            <materialDesign:Card Margin="8" Padding="20" Background="#C62828">
                <StackPanel>
                    <DockPanel>
                        <materialDesign:PackIcon Kind="AlertCircle" Width="32" Height="32"
                                                 Foreground="White" DockPanel.Dock="Right" />
                        <TextBlock Text="Failed" FontSize="14" Foreground="#FFCDD2" />
                    </DockPanel>
                    <TextBlock Text="{Binding FailedCount}" FontSize="42" FontWeight="Bold"
                               Foreground="White" Margin="0,8,0,0" />
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>

        <!-- Middle: Current Job Progress -->
        <materialDesign:Card Grid.Row="1" Margin="8,0,8,16" Padding="20">
            <StackPanel>
                <DockPanel Margin="0,0,0,12">
                    <materialDesign:PackIcon Kind="Play" Width="24" Height="24"
                                             VerticalAlignment="Center" Margin="0,0,8,0"
                                             Foreground="{DynamicResource PrimaryHueMidBrush}" />
                    <TextBlock Text="Current Job" FontSize="16" FontWeight="Medium"
                               VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                                HorizontalAlignment="Right">
                        <TextBlock Text="Speed: " Opacity="0.6" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding RenderSpeed}" VerticalAlignment="Center"
                                   Margin="0,0,16,0" />
                        <TextBlock Text="ETA: " Opacity="0.6" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding RenderEta}" VerticalAlignment="Center"
                                   FontFamily="Consolas" />
                    </StackPanel>
                </DockPanel>

                <DockPanel Margin="0,0,0,8">
                    <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center">
                        <Run Text="Job: " Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" />
                        <Run Text="{Binding CurrentJobId}" FontWeight="Medium" />
                    </TextBlock>
                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                               VerticalAlignment="Center">
                        <Run Text="Step: " Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" />
                        <Run Text="{Binding CurrentStep}" FontWeight="Medium"
                             Foreground="{DynamicResource SecondaryHueMidBrush}" />
                    </TextBlock>
                </DockPanel>

                <ProgressBar Value="{Binding RenderProgress}" Minimum="0" Maximum="100"
                             Height="16" Margin="0,0,0,4"
                             materialDesign:TransitionAssist.DisableTransitions="True" />

                <TextBlock HorizontalAlignment="Right" FontSize="12" Opacity="0.7">
                    <Run Text="{Binding RenderProgress, StringFormat={}{0:F1}}" />
                    <Run Text="%" />
                </TextBlock>
            </StackPanel>
        </materialDesign:Card>

        <!-- Bottom: Recent Activity -->
        <materialDesign:Card Grid.Row="2" Margin="8,0,8,0" Padding="16">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <materialDesign:PackIcon Kind="History" Width="22" Height="22"
                                             VerticalAlignment="Center" Margin="0,0,8,0"
                                             Foreground="{DynamicResource PrimaryHueMidBrush}" />
                    <TextBlock Text="Recent Activity" FontSize="16" FontWeight="Medium"
                               VerticalAlignment="Center" />
                </DockPanel>

                <ListBox ItemsSource="{Binding RecentActivities}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12"
                                       Margin="4,2" Opacity="0.85" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
