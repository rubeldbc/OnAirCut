<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <RootNamespace>OnAirCut.RenderServer</RootNamespace>
    <AssemblyName>OnAirCut.RenderServer</AssemblyName>
    <ApplicationIcon>Resources\app.ico</ApplicationIcon>
    <Version>1.0.0</Version>
    <Description>OnAirCut Render Server - FFmpeg Render Pipeline and Job Processing</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\OnAirCut Recorder\src\OnAirCut.Core\OnAirCut.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="MaterialDesignThemes" Version="5.*" />
    <PackageReference Include="MaterialDesignColors" Version="5.*" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.*" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="8.*" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="8.*" />
    <PackageReference Include="CliWrap" Version="3.*" />
    <PackageReference Include="SixLabors.ImageSharp" Version="3.*" />
    <PackageReference Include="Tesseract" Version="5.*" />
    <PackageReference Include="Serilog" Version="4.*" />
    <PackageReference Include="Serilog.Sinks.File" Version="6.*" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Resources\app.ico" />
  </ItemGroup>

  <!-- Copy lib/ folder (ffmpeg, tessdata) to output directory -->
  <ItemGroup>
    <None Include="lib\**\*" CopyToOutputDirectory="PreserveNewest" LinkBase="lib" />
  </ItemGroup>

  <!-- Copy settings.json to output directory -->
  <ItemGroup>
    <None Include="settings.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
