<UserControl x:Class="OnAirCut.Recorder.Views.AdvertiseManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:OnAirCut.Recorder.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:AdvertiseManagerViewModel}">

    <UserControl.Resources>
        <!-- Tiny slider style -->
        <Style x:Key="TinySlider" TargetType="Slider">
            <Setter Property="Height" Value="16" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition x:Name="PanelColumn" Width="300" MinWidth="240" MaxWidth="500" />
        </Grid.ColumnDefinitions>

        <!-- Left: Canvas -->
        <materialDesign:Card Grid.Column="0" Margin="4" Padding="4">
            <Grid>
                <Border Background="#1A1A2E" CornerRadius="4">
                    <Grid>
                        <Image x:Name="BackgroundImage" Source="{Binding BackgroundFrame}" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <Canvas x:Name="AdCanvas" Background="Transparent"
                                MouseLeftButtonDown="AdCanvas_MouseLeftButtonDown"
                                MouseMove="AdCanvas_MouseMove"
                                MouseLeftButtonUp="AdCanvas_MouseLeftButtonUp"
                                SizeChanged="AdCanvas_SizeChanged" />
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding BackgroundFrame}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <materialDesign:PackIcon Kind="ImageOff" Width="48" Height="48"
                                                     HorizontalAlignment="Center" Foreground="#555" />
                            <TextBlock Text="Capture a frame from the live preview"
                                       FontSize="13" Foreground="#555"
                                       HorizontalAlignment="Center" Margin="0,8,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Coordinate Display -->
                <Border Background="#CC000000" CornerRadius="4" Padding="8,4"
                        HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="8">
                    <TextBlock FontFamily="Consolas" FontSize="10" Foreground="White">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Doggy X:{0:F0} Y:{1:F0} W:{2:F0} H:{3:F0}">
                                <Binding Path="DoggyPositionX" />
                                <Binding Path="DoggyPositionY" />
                                <Binding Path="DoggyWidth" />
                                <Binding Path="DoggyHeight" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </Border>

                <Button Command="{Binding CaptureFrameCommand}"
                        Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="0,0,12,12" ToolTip="Capture frame from live preview">
                    <materialDesign:PackIcon Kind="Camera" />
                </Button>
            </Grid>
        </materialDesign:Card>

        <!-- Resizable Splitter -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center"
                      VerticalAlignment="Stretch" Background="Transparent"
                      ShowsPreview="True" ResizeBehavior="PreviousAndNext"
                      DragCompleted="GridSplitter_DragCompleted" />

        <!-- Right: Properties Panel -->
        <materialDesign:Card Grid.Column="2" Margin="4" Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Ad Set Selector -->
                    <TextBlock Text="AD SET" FontSize="9" FontWeight="Medium" Opacity="0.5" Margin="0,0,0,2" />
                    <ComboBox ItemsSource="{Binding AdSetNames}"
                              SelectedItem="{Binding SelectedAdSetName}"
                              materialDesign:HintAssist.Hint="Select Ad Set"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Margin="0,0,0,8" FontSize="11" />

                    <Separator Margin="0,0,0,4" />

                    <!-- ======== DOGGY (Floating Logo) ======== -->
                    <Expander Expanded="Expander_Expanded" Tag="0"
                              materialDesign:ExpanderAssist.HorizontalHeaderPadding="0">
                        <Expander.Header>
                            <DockPanel>
                                <CheckBox DockPanel.Dock="Left" IsChecked="{Binding DoggyEnabled}"
                                          Margin="0,0,6,0" VerticalAlignment="Center" />
                                <materialDesign:PackIcon Kind="ImageFilterHdr" Width="14" Height="14"
                                                         VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBlock Text="Floating Logo" FontWeight="Medium" FontSize="11"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                        </Expander.Header>
                        <StackPanel Margin="0,4,0,0">
                            <TextBlock Text="FILE" FontSize="8" Opacity="0.5" />
                            <ComboBox ItemsSource="{Binding AvailableFiles}" SelectedItem="{Binding DoggyFile}"
                                      materialDesign:HintAssist.Hint="Select file"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      FontSize="10" Margin="0,0,0,4" />

                            <TextBlock Text="START FROM (sec)" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,4">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding DoggyStartFrom}" Minimum="0" Maximum="9999"
                                    />
                                <Slider Value="{Binding DoggyStartFrom}" Minimum="0" Maximum="300" Style="{StaticResource TinySlider}" />
                            </DockPanel>

                            <TextBlock Text="POSITION X" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,3">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding DoggyPositionX}" Minimum="0" Maximum="1920" />
                                <Slider Value="{Binding DoggyPositionX}" Minimum="0" Maximum="1920" Style="{StaticResource TinySlider}" />
                            </DockPanel>

                            <TextBlock Text="POSITION Y" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,3">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding DoggyPositionY}" Minimum="0" Maximum="1080" />
                                <Slider Value="{Binding DoggyPositionY}" Minimum="0" Maximum="1080" Style="{StaticResource TinySlider}" />
                            </DockPanel>

                            <TextBlock Text="WIDTH" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,3">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding DoggyWidth}" Minimum="10" Maximum="1920" />
                                <Slider Value="{Binding DoggyWidth}" Minimum="10" Maximum="1920" Style="{StaticResource TinySlider}" />
                            </DockPanel>

                            <TextBlock Text="HEIGHT" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,3">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding DoggyHeight}" Minimum="10" Maximum="1080" />
                                <Slider Value="{Binding DoggyHeight}" Minimum="10" Maximum="1080" Style="{StaticResource TinySlider}" />
                            </DockPanel>

                            <TextBlock Text="CROP TOP" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,3">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding DoggyCropTop}" Minimum="0" Maximum="500" />
                                <Slider Value="{Binding DoggyCropTop}" Minimum="0" Maximum="500" Style="{StaticResource TinySlider}" />
                            </DockPanel>

                            <TextBlock Text="CROP RIGHT" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,3">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding DoggyCropRight}" Minimum="0" Maximum="500" />
                                <Slider Value="{Binding DoggyCropRight}" Minimum="0" Maximum="500" Style="{StaticResource TinySlider}" />
                            </DockPanel>

                            <TextBlock Text="CROP BOTTOM" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,3">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding DoggyCropBottom}" Minimum="0" Maximum="500" />
                                <Slider Value="{Binding DoggyCropBottom}" Minimum="0" Maximum="500" Style="{StaticResource TinySlider}" />
                            </DockPanel>

                            <TextBlock Text="CROP LEFT" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,3">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding DoggyCropLeft}" Minimum="0" Maximum="500" />
                                <Slider Value="{Binding DoggyCropLeft}" Minimum="0" Maximum="500" Style="{StaticResource TinySlider}" />
                            </DockPanel>

                            <TextBlock Text="OPACITY" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,3">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding DoggyOpacity}" Minimum="0" Maximum="1" />
                                <Slider Value="{Binding DoggyOpacity}" Minimum="0" Maximum="1" Style="{StaticResource TinySlider}" />
                            </DockPanel>
                        </StackPanel>
                    </Expander>

                    <Separator Margin="0,4" />

                    <!-- ======== POPUP ======== -->
                    <Expander Expanded="Expander_Expanded" Tag="1"
                              materialDesign:ExpanderAssist.HorizontalHeaderPadding="0">
                        <Expander.Header>
                            <DockPanel>
                                <CheckBox DockPanel.Dock="Left" IsChecked="{Binding PopupEnabled}"
                                          Margin="0,0,6,0" VerticalAlignment="Center" />
                                <materialDesign:PackIcon Kind="PictureInPictureTopRight" Width="14" Height="14"
                                                         VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBlock Text="Popup" FontWeight="Medium" FontSize="11"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                        </Expander.Header>
                        <StackPanel Margin="0,4,0,0">
                            <TextBlock Text="FILE" FontSize="8" Opacity="0.5" />
                            <ComboBox ItemsSource="{Binding AvailableFiles}" SelectedItem="{Binding PopupFile}"
                                      materialDesign:HintAssist.Hint="Select file"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      FontSize="10" Margin="0,0,0,4" />

                            <TextBlock Text="START FROM (sec)" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,4">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding PopupStartFrom}" Minimum="0" Maximum="9999"
                                    />
                                <Slider Value="{Binding PopupStartFrom}" Minimum="0" Maximum="300" Style="{StaticResource TinySlider}" />
                            </DockPanel>

                            <TextBlock Text="DURATION PER TIME (sec)" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,4">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding PopupDurationPerTime}" Minimum="1" Maximum="120"
                                    />
                                <Slider Value="{Binding PopupDurationPerTime}" Minimum="1" Maximum="60" Style="{StaticResource TinySlider}" />
                            </DockPanel>

                            <TextBlock Text="TOTAL PLAY (times)" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,4">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding PopupTotalPlay}" Minimum="1" Maximum="99" />
                                <Slider Value="{Binding PopupTotalPlay}" Minimum="1" Maximum="20"
                                        Style="{StaticResource TinySlider}"
                                        IsSnapToTickEnabled="True" TickFrequency="1" />
                            </DockPanel>

                            <TextBlock Text="POSITION X" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,3">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding PopupPositionX}" Minimum="0" Maximum="1920" />
                                <Slider Value="{Binding PopupPositionX}" Minimum="0" Maximum="1920" Style="{StaticResource TinySlider}" />
                            </DockPanel>

                            <TextBlock Text="POSITION Y" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,3">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding PopupPositionY}" Minimum="0" Maximum="1080" />
                                <Slider Value="{Binding PopupPositionY}" Minimum="0" Maximum="1080" Style="{StaticResource TinySlider}" />
                            </DockPanel>

                            <TextBlock Text="WIDTH" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,3">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding PopupWidth}" Minimum="10" Maximum="1920" />
                                <Slider Value="{Binding PopupWidth}" Minimum="10" Maximum="1920" Style="{StaticResource TinySlider}" />
                            </DockPanel>

                            <TextBlock Text="HEIGHT" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,3">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding PopupHeight}" Minimum="10" Maximum="1080" />
                                <Slider Value="{Binding PopupHeight}" Minimum="10" Maximum="1080" Style="{StaticResource TinySlider}" />
                            </DockPanel>

                            <TextBlock Text="CROP TOP" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,3">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding PopupCropTop}" Minimum="0" Maximum="500" />
                                <Slider Value="{Binding PopupCropTop}" Minimum="0" Maximum="500" Style="{StaticResource TinySlider}" />
                            </DockPanel>

                            <TextBlock Text="CROP RIGHT" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,3">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding PopupCropRight}" Minimum="0" Maximum="500" />
                                <Slider Value="{Binding PopupCropRight}" Minimum="0" Maximum="500" Style="{StaticResource TinySlider}" />
                            </DockPanel>

                            <TextBlock Text="CROP BOTTOM" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,3">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding PopupCropBottom}" Minimum="0" Maximum="500" />
                                <Slider Value="{Binding PopupCropBottom}" Minimum="0" Maximum="500" Style="{StaticResource TinySlider}" />
                            </DockPanel>

                            <TextBlock Text="CROP LEFT" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,3">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding PopupCropLeft}" Minimum="0" Maximum="500" />
                                <Slider Value="{Binding PopupCropLeft}" Minimum="0" Maximum="500" Style="{StaticResource TinySlider}" />
                            </DockPanel>

                            <TextBlock Text="OPACITY" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,3">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding PopupOpacity}" Minimum="0" Maximum="1" />
                                <Slider Value="{Binding PopupOpacity}" Minimum="0" Maximum="1" Style="{StaticResource TinySlider}" />
                            </DockPanel>
                        </StackPanel>
                    </Expander>

                    <Separator Margin="0,4" />

                    <!-- ======== TVC ======== -->
                    <Expander Expanded="Expander_Expanded" Tag="2"
                              materialDesign:ExpanderAssist.HorizontalHeaderPadding="0">
                        <Expander.Header>
                            <DockPanel>
                                <CheckBox DockPanel.Dock="Left" IsChecked="{Binding TvcEnabled}"
                                          Margin="0,0,6,0" VerticalAlignment="Center" />
                                <materialDesign:PackIcon Kind="Television" Width="14" Height="14"
                                                         VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBlock Text="TVC" FontWeight="Medium" FontSize="11"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                        </Expander.Header>
                        <StackPanel Margin="0,4,0,0">
                            <TextBlock Text="FILE" FontSize="8" Opacity="0.5" />
                            <ComboBox ItemsSource="{Binding AvailableFiles}" SelectedItem="{Binding TvcFile}"
                                      materialDesign:HintAssist.Hint="Select file"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      FontSize="10" Margin="0,0,0,4" />

                            <TextBlock Text="INSERT COUNT" FontSize="8" Opacity="0.5" />
                            <DockPanel Margin="0,0,0,3">
                                <materialDesign:NumericUpDown DockPanel.Dock="Right" Width="64"
                                    Value="{Binding TvcCount}" Minimum="1" Maximum="99" />
                                <Slider Value="{Binding TvcCount}" Minimum="1" Maximum="10"
                                        Style="{StaticResource TinySlider}"
                                        IsSnapToTickEnabled="True" TickFrequency="1" />
                            </DockPanel>
                        </StackPanel>
                    </Expander>

                    <Separator Margin="0,4" />

                    <!-- Save Button -->
                    <Button Command="{Binding SaveConfigCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="4"
                            HorizontalAlignment="Stretch" Margin="0,2,0,0" Padding="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" Margin="0,0,6,0" VerticalAlignment="Center" />
                            <TextBlock Text="Save Config" VerticalAlignment="Center" FontSize="12" />
                        </StackPanel>
                    </Button>

                    <TextBlock Text="{Binding StatusMessage}" FontSize="10" Opacity="0.6"
                               Margin="0,4,0,0" TextWrapping="Wrap" />

                    <Separator Margin="0,4" />

                    <!-- JSON Preview -->
                    <Expander materialDesign:ExpanderAssist.HorizontalHeaderPadding="0">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CodeJson" Width="14" Height="14"
                                                         VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBlock Text="Config JSON" FontWeight="Medium" FontSize="11"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Expander.Header>
                        <Border Background="#1A1A2E" CornerRadius="4"
                                Padding="6" Margin="0,4,0,0" MaxHeight="250">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding ConfigJsonText}" FontFamily="Consolas"
                                           FontSize="9" Foreground="#DDD" TextWrapping="NoWrap" />
                            </ScrollViewer>
                        </Border>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </materialDesign:Card>
    </Grid>
</UserControl>
