<UserControl x:Class="OnAirCut.Recorder.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:OnAirCut.Recorder.ViewModels"
             xmlns:converters="clr-namespace:OnAirCut.Recorder.Converters"
             xmlns:views="clr-namespace:OnAirCut.Recorder.Views"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Style="{StaticResource MaterialDesignFilledTabControl}">

            <!-- General Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Cog" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="General" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left" Margin="16">

                        <TextBlock Text="OPERATOR" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <TextBox Text="{Binding OperatorName, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Operator Name"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,16" />

                        <TextBlock Text="RENDER SERVER" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <TextBox Text="{Binding RenderServerApiUrl, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Render Server API URL"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,16" />

                        <CheckBox Content="Auto-submit on recording stop"
                                  IsChecked="{Binding AutoSubmitOnRecordStop}"
                                  Margin="0,0,0,16" />

                        <!-- Test Connection -->
                        <Button Command="{Binding TestConnectionCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                materialDesign:ButtonAssist.CornerRadius="4"
                                HorizontalAlignment="Left" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="TestTube" Margin="0,0,8,0"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Test Connections" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <TextBlock Text="{Binding ConnectionTestResult}" FontSize="11"
                                   Opacity="0.7" TextWrapping="Wrap" />

                        <Separator Margin="0,16" />

                        <!-- Dependencies Section -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="Download" Width="20" Height="20"
                                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Dependencies" FontSize="16" FontWeight="Medium"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <Button Command="{Binding CheckDependenciesCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                materialDesign:ButtonAssist.CornerRadius="4"
                                Content="Check All" Margin="0,0,0,8" HorizontalAlignment="Left" />

                        <Button Command="{Binding DownloadAllMissingCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                materialDesign:ButtonAssist.CornerRadius="4"
                                Background="#66BB6A" Foreground="White"
                                Content="Download All Missing" Margin="0,0,0,12" HorizontalAlignment="Left" />

                        <ItemsControl ItemsSource="{Binding Dependencies}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <materialDesign:Card Padding="12" Margin="0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Name + Status -->
                                            <StackPanel Grid.Column="0" Grid.Row="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="13" />
                                                    <TextBlock Text="{Binding Size}" FontSize="11" Opacity="0.5"
                                                               Margin="8,0,0,0" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" FontSize="10" Opacity="0.6" />
                                                <DockPanel Margin="0,2,0,0">
                                                    <!-- Green check or Red X -->
                                                    <materialDesign:PackIcon Width="14" Height="14" DockPanel.Dock="Left"
                                                                             VerticalAlignment="Center" Margin="0,0,4,0">
                                                        <materialDesign:PackIcon.Style>
                                                            <Style TargetType="materialDesign:PackIcon">
                                                                <Setter Property="Kind" Value="CloseCircle" />
                                                                <Setter Property="Foreground" Value="#EF5350" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                                        <Setter Property="Kind" Value="CheckCircle" />
                                                                        <Setter Property="Foreground" Value="#66BB6A" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </materialDesign:PackIcon.Style>
                                                    </materialDesign:PackIcon>
                                                    <TextBlock Text="{Binding Status}" FontSize="11"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                </DockPanel>
                                            </StackPanel>

                                            <!-- Download Button -->
                                            <Button Grid.Column="1" Grid.Row="0"
                                                    Command="{Binding DataContext.DownloadDependencyCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    materialDesign:ButtonAssist.CornerRadius="4"
                                                    Content="Download" Padding="8,4" FontSize="11"
                                                    Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />

                                            <!-- Progress Bar (when downloading) -->
                                            <Grid Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                                                  Margin="0,6,0,0"
                                                  Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibility}}">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <ProgressBar Grid.Row="0" Value="{Binding DownloadProgress}"
                                                             Minimum="0" Maximum="100" Height="6" />
                                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding DownloadProgress, StringFormat='{}{0:F0}%'}"
                                                               FontSize="10" />
                                                    <TextBlock Text="{Binding DownloadSpeed}" FontSize="10"
                                                               Margin="12,0,0,0" Opacity="0.6" />
                                                    <TextBlock Text="{Binding Eta}" FontSize="10"
                                                               Margin="12,0,0,0" Opacity="0.6" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </materialDesign:Card>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Shared Folder Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FolderNetwork" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Shared Folder" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left" Margin="16">

                        <TextBlock Text="SHARED FOLDER PATH" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <DockPanel Margin="0,0,0,16">
                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    Command="{Binding BrowseSharedFolderCommand}"
                                    ToolTip="Browse" Margin="8,0,0,0">
                                <materialDesign:PackIcon Kind="FolderOpen" />
                            </Button>
                            <TextBox Text="{Binding SharedFolderPath, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Shared folder path"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        </DockPanel>

                        <!-- Create Folder Structure -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Button Command="{Binding CreateFolderStructureCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="4"
                                    Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FolderPlus" Margin="0,0,8,0"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Create Folder Structure" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ValidateSharedFolderCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="4">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FolderCheck" Margin="0,0,8,0"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Validate" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Validation Status -->
                        <TextBlock Text="FOLDER VALIDATION" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding FolderValidationItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <materialDesign:PackIcon Width="18" Height="18"
                                                                 VerticalAlignment="Center" Margin="0,0,8,0">
                                            <materialDesign:PackIcon.Style>
                                                <Style TargetType="materialDesign:PackIcon">
                                                    <Setter Property="Kind" Value="CloseCircle" />
                                                    <Setter Property="Foreground" Value="#EF5350" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Exists}" Value="True">
                                                            <Setter Property="Kind" Value="CheckCircle" />
                                                            <Setter Property="Foreground" Value="#66BB6A" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:PackIcon.Style>
                                        </materialDesign:PackIcon>
                                        <TextBlock Text="{Binding FolderName}" VerticalAlignment="Center"
                                                   FontSize="13" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Recording Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Record" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Recording" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left" Margin="16">

                        <TextBlock Text="RECORDING FORMAT" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding RecordingFormat, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Format (mp4, mkv...)"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                            <TextBox Grid.Column="2"
                                     Text="{Binding RecordingCodec, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Codec (libx264...)"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        </Grid>

                        <TextBlock Text="EXTERNAL TOOLS" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <DockPanel Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    Command="{Binding BrowseFfmpegCommand}"
                                    ToolTip="Browse" Margin="8,0,0,0">
                                <materialDesign:PackIcon Kind="FolderOpen" />
                            </Button>
                            <TextBox Text="{Binding FfmpegPath, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="FFmpeg path"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    Command="{Binding BrowseYtDlpCommand}"
                                    ToolTip="Browse" Margin="8,0,0,0">
                                <materialDesign:PackIcon Kind="FolderOpen" />
                            </Button>
                            <TextBox Text="{Binding YtDlpPath, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="yt-dlp path"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        </DockPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Audio Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="VolumeHigh" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Audio" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left" Margin="16">

                        <TextBlock Text="AUDIO DEVICE" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <TextBox Text="{Binding AudioDevice, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Audio Device"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,16" />

                        <TextBlock Text="MONITOR VOLUME" FontSize="12" FontWeight="Medium"
                                   Opacity="0.7" Margin="0,0,0,8" />
                        <DockPanel>
                            <TextBlock Text="Monitor Volume:" VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="{Binding MonitorVolume, StringFormat='{}{0}%'}"
                                       DockPanel.Dock="Right" VerticalAlignment="Center"
                                       Width="40" TextAlignment="Right" />
                            <Slider Minimum="0" Maximum="100"
                                    Value="{Binding MonitorVolume}"
                                    VerticalAlignment="Center" />
                        </DockPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Advertise Manager Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Advertisements" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Advertise Manager" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <views:AdvertiseManagerView DataContext="{Binding AdvertiseManager}" />
            </TabItem>

            <!-- OCR Region Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="TextRecognition" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="OCR Region" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>

                    <!-- Image Display with Marquee Selection Overlay -->
                    <materialDesign:Card Grid.Column="0" Margin="4" Padding="4">
                        <Grid>
                            <Border Background="#1A1A2E" CornerRadius="4">
                                <Grid>
                                    <!-- Frame Image -->
                                    <Image x:Name="OcrImage" Source="{Binding FrameImage}" Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality" />

                                    <!-- Canvas for marquee selection -->
                                    <Canvas x:Name="OcrCanvas" Background="Transparent"
                                            MouseLeftButtonDown="OcrImage_MouseLeftButtonDown"
                                            MouseMove="OcrImage_MouseMove"
                                            MouseLeftButtonUp="OcrImage_MouseLeftButtonUp" />

                                    <!-- No Image Placeholder -->
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FrameImage}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <materialDesign:PackIcon Kind="ImageOff" Width="48" Height="48"
                                                                 HorizontalAlignment="Center"
                                                                 Foreground="#555" />
                                        <TextBlock Text="Load an image or capture a frame, then draw a selection rectangle"
                                                   FontSize="13" Foreground="#555"
                                                   HorizontalAlignment="Center" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Coordinate Display -->
                            <Border Background="#CC000000" CornerRadius="4"
                                    Padding="8,4" HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom" Margin="8">
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="White">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="X:{0} Y:{1} W:{2} H:{3}">
                                            <Binding Path="OcrCropX" />
                                            <Binding Path="OcrCropY" />
                                            <Binding Path="OcrCropWidth" />
                                            <Binding Path="OcrCropHeight" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Border>
                        </Grid>
                    </materialDesign:Card>

                    <!-- OCR Settings Panel -->
                    <materialDesign:Card Grid.Column="1" Margin="4" Padding="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Header -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <materialDesign:PackIcon Kind="TextRecognition" Width="20" Height="20"
                                                             VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="OCR Region" FontSize="16" FontWeight="Medium"
                                               VerticalAlignment="Center" />
                                </StackPanel>

                                <!-- Profile Management -->
                                <TextBlock Text="PROFILE" FontSize="10" FontWeight="Medium" Opacity="0.6" Margin="0,0,0,4" />

                                <ComboBox ItemsSource="{Binding OcrProfileNames}"
                                          SelectedItem="{Binding SelectedOcrProfileName}"
                                          materialDesign:HintAssist.Hint="Select Profile"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          Margin="0,0,0,8" FontSize="12" />

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="New profile name"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="12" />
                                    <Button Grid.Column="2" Command="{Binding SaveOcrProfileToSharedCommand}"
                                            Style="{StaticResource MaterialDesignRaisedButton}"
                                            Padding="12,6" ToolTip="Save profile to shared folder">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ContentSave" Margin="0,0,4,0" />
                                            <TextBlock Text="Save" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <Button Command="{Binding DeleteOcrProfileFromSharedCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Foreground="#EF5350" HorizontalAlignment="Left"
                                        Padding="8,4" FontSize="11" Margin="0,0,0,8"
                                        Content="Delete Selected Profile" />

                                <Separator Margin="0,4" />

                                <!-- Crop Coordinates -->
                                <TextBlock Text="CROP REGION" FontSize="10" FontWeight="Medium"
                                           Opacity="0.6" Margin="0,8,0,6" />

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBox Grid.Row="0" Grid.Column="0"
                                             Text="{Binding OcrCropX}"
                                             materialDesign:HintAssist.Hint="X"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                                    <TextBox Grid.Row="0" Grid.Column="2"
                                             Text="{Binding OcrCropY}"
                                             materialDesign:HintAssist.Hint="Y"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                                    <TextBox Grid.Row="2" Grid.Column="0"
                                             Text="{Binding OcrCropWidth}"
                                             materialDesign:HintAssist.Hint="Width"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                                    <TextBox Grid.Row="2" Grid.Column="2"
                                             Text="{Binding OcrCropHeight}"
                                             materialDesign:HintAssist.Hint="Height"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                                </Grid>

                                <Separator Margin="0,4" />

                                <!-- Actions -->
                                <StackPanel Margin="0,8,0,0">
                                    <Button Command="{Binding LoadOcrImageCommand}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            materialDesign:ButtonAssist.CornerRadius="4"
                                            HorizontalAlignment="Stretch" Margin="0,0,0,6">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ImagePlus" Margin="0,0,8,0"
                                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="Load Image" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>

                                    <Button Command="{Binding CaptureOcrFrameCommand}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            materialDesign:ButtonAssist.CornerRadius="4"
                                            HorizontalAlignment="Stretch" Margin="0,0,0,6">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Camera" Margin="0,0,8,0"
                                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="Capture Frame" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>

                                    <Button Command="{Binding TestOcrCommand}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            materialDesign:ButtonAssist.CornerRadius="4"
                                            HorizontalAlignment="Stretch" Margin="0,0,0,6">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="TestTube" Margin="0,0,8,0"
                                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="Test OCR" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>

                                    <!-- Save Region Button -->
                                    <Button Command="{Binding SaveOcrRegionCommand}"
                                            Style="{StaticResource MaterialDesignRaisedButton}"
                                            materialDesign:ButtonAssist.CornerRadius="4"
                                            HorizontalAlignment="Stretch" Margin="0,4,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ContentSave" Margin="0,0,8,0"
                                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="Save Region" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>

                                    <!-- Clear Region Button -->
                                    <Button Command="{Binding ClearOcrRegionCommand}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Foreground="#EF5350"
                                            materialDesign:ButtonAssist.CornerRadius="4"
                                            HorizontalAlignment="Stretch" Margin="0,6,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Delete" Margin="0,0,8,0"
                                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="Clear Region" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <!-- Test Result -->
                                <Border Background="#1A1A2E" CornerRadius="4"
                                        Padding="8" Margin="0,8,0,0"
                                        MinHeight="40">
                                    <TextBlock Text="{Binding OcrTestResult}" FontSize="11"
                                               TextWrapping="Wrap" Opacity="0.8" />
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- History Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="History" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="History" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <views:HistoryPanelView DataContext="{Binding HistoryPanel}" />
            </TabItem>
        </TabControl>

        <!-- Action Buttons (always visible at bottom) -->
        <Border Grid.Row="1" Padding="16,8"
                BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           Margin="0,0,16,0" FontSize="12" Opacity="0.7" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Button Command="{Binding ResetCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            materialDesign:ButtonAssist.CornerRadius="4"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Undo" Margin="0,0,8,0"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Reset" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SaveCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" Margin="0,0,8,0"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Save Settings" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
