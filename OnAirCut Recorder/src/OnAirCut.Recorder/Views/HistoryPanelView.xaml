<UserControl x:Class="OnAirCut.Recorder.Views.HistoryPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:OnAirCut.Recorder.ViewModels"
             xmlns:converters="clr-namespace:OnAirCut.Recorder.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:HistoryPanelViewModel}"
>

    <UserControl.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColor" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <materialDesign:Card Padding="12" Margin="4">
        <DockPanel>
            <!-- Header -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <materialDesign:PackIcon Kind="History" Width="20" Height="20"
                                         VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Text="History" FontSize="16" FontWeight="Medium"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding TotalCount, StringFormat=' ({0} items)'}"
                           FontSize="12" Opacity="0.6"
                           VerticalAlignment="Center" Margin="4,0,0,0" />

                <!-- Loading indicator -->
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             Value="0" IsIndeterminate="True"
                             Width="16" Height="16" Margin="8,0,0,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>

            <!-- Search Bar -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Search Text -->
                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Search titles..."
                         materialDesign:TextFieldAssist.HasLeadingIcon="True"
                         materialDesign:TextFieldAssist.LeadingIcon="Search"
                         FontSize="12" Margin="0,0,8,0"
                         VerticalAlignment="Center" />

                <!-- Date From -->
                <DatePicker Grid.Column="1"
                            SelectedDate="{Binding DateFrom}"
                            materialDesign:HintAssist.Hint="From"
                            FontSize="11" Width="120" Margin="0,0,4,0"
                            VerticalAlignment="Center" />

                <!-- Date To -->
                <DatePicker Grid.Column="2"
                            SelectedDate="{Binding DateTo}"
                            materialDesign:HintAssist.Hint="To"
                            FontSize="11" Width="120" Margin="0,0,4,0"
                            VerticalAlignment="Center" />

                <!-- Status Filter -->
                <ComboBox Grid.Column="3"
                          ItemsSource="{Binding AvailableStatuses}"
                          SelectedItem="{Binding SelectedStatus}"
                          materialDesign:HintAssist.Hint="Status"
                          FontSize="11" Width="110" Margin="0,0,4,0"
                          VerticalAlignment="Center" />

                <!-- Search Button -->
                <Button Grid.Column="4"
                        Command="{Binding SearchCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="4"
                        Padding="8,4" Margin="0,0,4,0"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Search" Width="16" Height="16"
                                                 Margin="0,0,4,0" VerticalAlignment="Center" />
                        <TextBlock Text="Search" FontSize="11" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Clear Button -->
                <Button Grid.Column="5"
                        Command="{Binding ClearFiltersCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        materialDesign:ButtonAssist.CornerRadius="4"
                        Padding="8,4" Margin="0,0,4,0"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FilterOff" Width="16" Height="16"
                                                 Margin="0,0,4,0" VerticalAlignment="Center" />
                        <TextBlock Text="Clear" FontSize="11" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Refresh Button -->
                <Button Grid.Column="6"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="Refresh"
                        Width="32" Height="32"
                        VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" />
                </Button>
            </Grid>

            <!-- Data Grid -->
            <DataGrid ItemsSource="{Binding Stories}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserSortColumns="True"
                      SelectionMode="Single"
                      materialDesign:DataGridAssist.CellPadding="8 4"
                      FontSize="12"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto">

                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Open File"
                                  Command="{Binding OpenFileCommand}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                            <MenuItem.Icon>
                                <materialDesign:PackIcon Kind="FileVideo" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Open File Location"
                                  Command="{Binding OpenFileLocationCommand}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                            <MenuItem.Icon>
                                <materialDesign:PackIcon Kind="FolderOpen" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Remove from List"
                                  Command="{Binding RemoveFromListCommand}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                            <MenuItem.Icon>
                                <materialDesign:PackIcon Kind="PlaylistRemove" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Remove from Disk" Foreground="#EF5350"
                                  Command="{Binding RemoveFromDiskCommand}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                            <MenuItem.Icon>
                                <materialDesign:PackIcon Kind="DeleteForever" Foreground="#EF5350" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Title" Binding="{Binding TitleNormalized}"
                                        Width="*" MinWidth="150" />
                    <DataGridTextColumn Header="On-Air Date"
                                        Binding="{Binding OnAirDateTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                        Width="130" />
                    <DataGridTextColumn Header="Duration"
                                        Binding="{Binding DurationSeconds, StringFormat='{}{0:F0}s'}"
                                        Width="70" />
                    <DataGridTextColumn Header="Source" Binding="{Binding SourceName}"
                                        Width="100" />
                    <DataGridTextColumn Header="Ad Set" Binding="{Binding AdSetName}"
                                        Width="90" />
                    <DataGridTemplateColumn Header="Status" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Padding="8,2"
                                        HorizontalAlignment="Left"
                                        Background="{Binding Status, Converter={StaticResource StatusToColor}}">
                                    <TextBlock Text="{Binding Status}" FontSize="10"
                                               FontWeight="Medium" Foreground="White" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Submitted By" Binding="{Binding SubmittedBy}"
                                        Width="90" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </materialDesign:Card>
</UserControl>
