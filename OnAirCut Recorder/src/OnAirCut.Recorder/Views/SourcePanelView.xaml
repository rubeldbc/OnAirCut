<UserControl x:Class="OnAirCut.Recorder.Views.SourcePanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:OnAirCut.Recorder.ViewModels"
             xmlns:converters="clr-namespace:OnAirCut.Recorder.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SourcePanelViewModel}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <converters:SourceTypeToVisibilityConverter x:Key="SourceTypeToVisibility" />
        <converters:SourceTypeToBoolConverter x:Key="SourceTypeToBool" />
    </UserControl.Resources>

    <materialDesign:Card Padding="12" Margin="4">
        <StackPanel>
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <materialDesign:PackIcon Kind="VideoInputAntenna" Width="20" Height="20"
                                         VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Text="Source" FontSize="16" FontWeight="Medium"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Source Type Selection -->
            <TextBlock Text="SOURCE TYPE" FontSize="10" Opacity="0.6" Margin="0,0,0,6"
                       FontWeight="Medium" />

            <RadioButton GroupName="SourceType" Margin="0,2"
                         IsChecked="{Binding SelectedSourceType, Converter={StaticResource SourceTypeToBool}, ConverterParameter=LiveFeed}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Videocam" Width="16" Height="16"
                                             Margin="0,0,6,0" VerticalAlignment="Center" />
                    <TextBlock Text="Live Feed" VerticalAlignment="Center" />
                </StackPanel>
            </RadioButton>

            <RadioButton GroupName="SourceType" Margin="0,2"
                         IsChecked="{Binding SelectedSourceType, Converter={StaticResource SourceTypeToBool}, ConverterParameter=LocalFile}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FileVideo" Width="16" Height="16"
                                             Margin="0,0,6,0" VerticalAlignment="Center" />
                    <TextBlock Text="Local File" VerticalAlignment="Center" />
                </StackPanel>
            </RadioButton>

            <RadioButton GroupName="SourceType" Margin="0,2"
                         IsChecked="{Binding SelectedSourceType, Converter={StaticResource SourceTypeToBool}, ConverterParameter=YouTubeUrl}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Youtube" Width="16" Height="16"
                                             Margin="0,0,6,0" VerticalAlignment="Center" />
                    <TextBlock Text="YouTube URL" VerticalAlignment="Center" />
                </StackPanel>
            </RadioButton>

            <Separator Margin="0,10" />

            <!-- Input Area -->
            <TextBlock Text="SOURCE INPUT" FontSize="10" Opacity="0.6" Margin="0,0,0,6"
                       FontWeight="Medium" />

            <!-- File Input -->
            <DockPanel Margin="0,4"
                       Visibility="{Binding SelectedSourceType, Converter={StaticResource SourceTypeToVisibility}, ConverterParameter=LocalFile}">
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource MaterialDesignIconButton}"
                        Command="{Binding BrowseFileCommand}"
                        ToolTip="Browse for file"
                        Width="32" Height="32"
                        Margin="4,0,0,0">
                    <materialDesign:PackIcon Kind="FolderOpen" Width="18" Height="18" />
                </Button>
                <TextBox Text="{Binding SourceUri, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="File path..."
                         FontSize="11" VerticalAlignment="Center" />
            </DockPanel>

            <!-- YouTube Input -->
            <TextBox Margin="0,4"
                     Text="{Binding SourceUri, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="YouTube URL..."
                     FontSize="11"
                     Visibility="{Binding SelectedSourceType, Converter={StaticResource SourceTypeToVisibility}, ConverterParameter=YouTubeUrl}" />

            <!-- Live Feed Device -->
            <ComboBox Margin="0,4"
                      ItemsSource="{Binding AvailableDevices}"
                      SelectedItem="{Binding SelectedDevice}"
                      materialDesign:HintAssist.Hint="Capture Device"
                      FontSize="11"
                      Visibility="{Binding SelectedSourceType, Converter={StaticResource SourceTypeToVisibility}, ConverterParameter=LiveFeed}" />

            <Separator Margin="0,10" />

            <!-- Connection Status -->
            <StackPanel Orientation="Horizontal" Margin="0,4">
                <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                         VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#EF5350" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Fill" Value="#66BB6A" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding ConnectionStatus}" FontSize="11"
                           VerticalAlignment="Center" Opacity="0.8" />
            </StackPanel>

            <!-- Connect/Disconnect Buttons -->
            <Button Margin="0,8,0,0"
                    Command="{Binding ConnectCommand}"
                    Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="4"
                    HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="Power" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="Connect" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Margin="0,8,0,0"
                    Command="{Binding DisconnectCommand}"
                    Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Foreground="#EF5350"
                    materialDesign:ButtonAssist.CornerRadius="4"
                    HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="PowerOff" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="Disconnect" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Separator Margin="0,10" />

            <!-- OCR Profile Selection -->
            <TextBlock Text="OCR PROFILE" FontSize="10" Opacity="0.6" Margin="0,0,0,4" FontWeight="Medium" />
            <ComboBox ItemsSource="{Binding OcrProfileNames}"
                      SelectedItem="{Binding SelectedOcrProfile}"
                      materialDesign:HintAssist.Hint="OCR Profile"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      FontSize="11" />
        </StackPanel>
    </materialDesign:Card>
</UserControl>
