<Window x:Class="OnAirCut.Recorder.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:OnAirCut.Recorder.ViewModels"
        xmlns:views="clr-namespace:OnAirCut.Recorder.Views"
        xmlns:converters="clr-namespace:OnAirCut.Recorder.Converters"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:MainWindowViewModel}"
        Title="{Binding Title}"
        WindowState="Maximized"
        MinHeight="600" MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MaterialDesignWindow}"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <materialDesign:ColorZone Grid.Row="0" Mode="PrimaryDark" Padding="10,8">
            <DockPanel>
                <!-- Left: App identity -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <materialDesign:PackIcon Kind="VideoVintage" Width="26" Height="26"
                                             VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Medium"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Right: Status indicators and actions -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                            HorizontalAlignment="Right" VerticalAlignment="Center">

                    <!-- Settings button -->
                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                            Command="{Binding OpenSettingsCommand}"
                            ToolTip="Settings"
                            Width="32" Height="32" Margin="0,0,12,0">
                        <materialDesign:PackIcon Kind="Settings" Width="20" Height="20" />
                    </Button>

                    <!-- Shared folder status -->
                    <Ellipse Width="10" Height="10" Margin="0,0,4,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#EF5350" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSharedFolderHealthy}" Value="True">
                                        <Setter Property="Fill" Value="#66BB6A" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <materialDesign:PackIcon Kind="FolderNetwork" Width="16" Height="16"
                                             VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.8" />
                    <TextBlock Text="{Binding SharedFolderStatus}" VerticalAlignment="Center"
                               Margin="0,0,16,0" FontSize="11" Opacity="0.8" />

                    <!-- Source status -->
                    <materialDesign:PackIcon Kind="Video" Width="16" Height="16"
                                             VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.8" />
                    <TextBlock Text="{Binding SourceStatus}" VerticalAlignment="Center"
                               Margin="0,0,16,0" FontSize="11" Opacity="0.8" />

                    <!-- Clock -->
                    <materialDesign:PackIcon Kind="ClockOutline" Width="16" Height="16"
                                             VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.8" />
                    <TextBlock Text="{Binding CurrentTime}" VerticalAlignment="Center"
                               FontSize="13" FontFamily="Consolas" FontWeight="Medium" />
                </StackPanel>
            </DockPanel>
        </materialDesign:ColorZone>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <!-- Normal recorder view -->
            <Grid Visibility="{Binding IsSettingsVisible, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="280" />
                </Grid.RowDefinitions>

                <!-- Main working area -->
                <Grid Grid.Row="0" Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Source Panel -->
                    <views:SourcePanelView Grid.Column="0"
                                           DataContext="{Binding SourcePanel}" />

                    <!-- Center: Preview + Recording Controls -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <views:PreviewPlayerView Grid.Row="0"
                                                 DataContext="{Binding PreviewPlayer}" />

                        <views:RecordingControlsView Grid.Row="1"
                                                     DataContext="{Binding RecordingControls}" />
                    </Grid>

                    <!-- Right: Ad Set Panel + Pending Clips -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Ad Sets -->
                        <views:AdSetPanelView Grid.Row="0"
                                              DataContext="{Binding AdSetPanel}" />

                        <!-- Pending Clips Queue -->
                        <materialDesign:Card Grid.Row="1" Padding="8" Margin="4,2,4,4"
                                             MaxHeight="220">
                            <DockPanel>
                                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="PlaylistPlay" Width="16" Height="16"
                                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Text="Pending Clips" FontSize="13" FontWeight="Medium"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding RecordingControls.PendingClipsCount, StringFormat=' ({0})'}"
                                                   FontSize="12" Opacity="0.6" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                                            Command="{Binding RecordingControls.SubmitAllPendingCommand}"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Foreground="#66BB6A" Padding="6,2" FontSize="11"
                                            Content="Submit All" ToolTip="Submit all pending clips" />
                                </DockPanel>

                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding RecordingControls.PendingClips}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                                                        BorderThickness="0,0,0,1" Padding="4,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding FileName}" FontSize="11"
                                                                       FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Duration, StringFormat='{}{0:mm\\:ss}'}"
                                                                           FontSize="9" Opacity="0.5" FontFamily="Consolas" />
                                                                <TextBlock Text=" | " FontSize="9" Opacity="0.3" />
                                                                <TextBlock Text="{Binding FileSize}" FontSize="9" Opacity="0.5" />
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <Button Grid.Column="1"
                                                                Command="{Binding DataContext.RecordingControls.SubmitPendingClipCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource MaterialDesignIconButton}"
                                                                Foreground="#66BB6A" Width="24" Height="24"
                                                                ToolTip="Submit">
                                                            <materialDesign:PackIcon Kind="Send" Width="14" Height="14" />
                                                        </Button>

                                                        <Button Grid.Column="2"
                                                                Command="{Binding DataContext.RecordingControls.RemovePendingClipCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource MaterialDesignIconButton}"
                                                                Foreground="#EF5350" Width="24" Height="24"
                                                                ToolTip="Remove">
                                                            <materialDesign:PackIcon Kind="Delete" Width="14" Height="14" />
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </materialDesign:Card>
                    </Grid>
                </Grid>

                <!-- Grid Splitter -->
                <GridSplitter Grid.Row="1" Height="5"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Background="Transparent"
                              ShowsPreview="True" />

                <!-- Bottom: History Panel -->
                <views:HistoryPanelView Grid.Row="2"
                                        DataContext="{Binding HistoryPanel}" />
            </Grid>

            <!-- Settings view overlay (solid background, covers entire content area) -->
            <Grid Visibility="{Binding IsSettingsVisible, Converter={StaticResource BoolToVisibility}}"
                  Background="{DynamicResource MaterialDesign.Brush.Background}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Settings header with back button -->
                <materialDesign:ColorZone Grid.Row="0" Mode="PrimaryMid" Padding="12,8">
                    <DockPanel>
                        <Button DockPanel.Dock="Left"
                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                Command="{Binding OpenSettingsCommand}"
                                ToolTip="Back to Recorder"
                                Width="32" Height="32" Margin="0,0,12,0">
                            <materialDesign:PackIcon Kind="ArrowLeft" Width="20" Height="20" />
                        </Button>
                        <materialDesign:PackIcon Kind="Cog" Width="22" Height="22"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Settings" FontSize="17" FontWeight="Medium"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </materialDesign:ColorZone>

                <views:SettingsView Grid.Row="1" DataContext="{Binding Settings}" />
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <materialDesign:ColorZone Grid.Row="2" Mode="PrimaryDark" Padding="10,4">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Information" Width="14" Height="14"
                                             VerticalAlignment="Center" Margin="0,0,6,0"
                                             Opacity="0.6" />
                    <TextBlock Text="{Binding RecordingControls.StatusMessage}"
                               FontSize="11" VerticalAlignment="Center" Opacity="0.8" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <TextBlock Text="OnAirCut Recorder v1.0" FontSize="10"
                               VerticalAlignment="Center" Opacity="0.5" />
                </StackPanel>
            </DockPanel>
        </materialDesign:ColorZone>
    </Grid>
</Window>
