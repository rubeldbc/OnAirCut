<UserControl x:Class="OnAirCut.Recorder.Views.OcrRegionEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:OnAirCut.Recorder.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:OcrRegionViewModel}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <!-- Image Display with Crop Overlay -->
        <materialDesign:Card Grid.Column="0" Margin="4" Padding="4">
            <Grid>
                <Border Background="#1A1A2E" CornerRadius="4">
                    <Grid>
                        <!-- Frame Image -->
                        <Image Source="{Binding FrameImage}" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality" />

                        <!-- Crop Rectangle Overlay -->
                        <Canvas x:Name="CropCanvas" Background="Transparent">
                            <Rectangle Canvas.Left="{Binding CropX}"
                                       Canvas.Top="{Binding CropY}"
                                       Width="{Binding CropWidth}"
                                       Height="{Binding CropHeight}"
                                       Stroke="#42A5F5" StrokeThickness="2"
                                       StrokeDashArray="4 2"
                                       Fill="#2242A5F5" />
                        </Canvas>

                        <!-- No Image Placeholder -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FrameImage}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <materialDesign:PackIcon Kind="ImageOff" Width="48" Height="48"
                                                     HorizontalAlignment="Center"
                                                     Foreground="#555" />
                            <TextBlock Text="Load an image or capture a frame"
                                       FontSize="13" Foreground="#555"
                                       HorizontalAlignment="Center" Margin="0,8,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Coordinate Display -->
                <Border Background="#CC000000" CornerRadius="4"
                        Padding="8,4" HorizontalAlignment="Left"
                        VerticalAlignment="Bottom" Margin="8">
                    <TextBlock FontFamily="Consolas" FontSize="11" Foreground="White">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="X:{0} Y:{1} W:{2} H:{3}">
                                <Binding Path="CropX" />
                                <Binding Path="CropY" />
                                <Binding Path="CropWidth" />
                                <Binding Path="CropHeight" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </Border>
            </Grid>
        </materialDesign:Card>

        <!-- OCR Settings Panel -->
        <materialDesign:Card Grid.Column="1" Margin="4" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <materialDesign:PackIcon Kind="TextRecognition" Width="20" Height="20"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="OCR Region" FontSize="16" FontWeight="Medium"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Profile Selection -->
                    <ComboBox ItemsSource="{Binding AvailableProfiles}"
                              SelectedItem="{Binding SelectedProfile}"
                              DisplayMemberPath="ProfileName"
                              materialDesign:HintAssist.Hint="Profile"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Margin="0,0,0,8" />

                    <TextBox Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Profile Name"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,8" />

                    <TextBox Text="{Binding SourceName, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Source Name"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,8" />

                    <Separator Margin="0,4" />

                    <!-- Crop Coordinates -->
                    <TextBlock Text="CROP REGION" FontSize="10" FontWeight="Medium"
                               Opacity="0.6" Margin="0,8,0,6" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0" Grid.Column="0"
                                 Text="{Binding CropX}"
                                 materialDesign:HintAssist.Hint="X"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        <TextBox Grid.Row="0" Grid.Column="2"
                                 Text="{Binding CropY}"
                                 materialDesign:HintAssist.Hint="Y"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        <TextBox Grid.Row="2" Grid.Column="0"
                                 Text="{Binding CropWidth}"
                                 materialDesign:HintAssist.Hint="Width"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        <TextBox Grid.Row="2" Grid.Column="2"
                                 Text="{Binding CropHeight}"
                                 materialDesign:HintAssist.Hint="Height"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                    </Grid>

                    <!-- Processing Options -->
                    <TextBlock Text="PROCESSING" FontSize="10" FontWeight="Medium"
                               Opacity="0.6" Margin="0,4,0,6" />

                    <TextBox Text="{Binding ResizeScale}"
                             materialDesign:HintAssist.Hint="Resize Scale"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,8" />

                    <ComboBox ItemsSource="{Binding ThresholdModes}"
                              SelectedItem="{Binding ThresholdMode}"
                              materialDesign:HintAssist.Hint="Threshold Mode"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Margin="0,0,0,8" />

                    <Separator Margin="0,4" />

                    <!-- Actions -->
                    <StackPanel Margin="0,8,0,0">
                        <Button Command="{Binding LoadImageCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                materialDesign:ButtonAssist.CornerRadius="4"
                                HorizontalAlignment="Stretch" Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ImagePlus" Margin="0,0,8,0"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Load Image" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding CaptureFrameCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                materialDesign:ButtonAssist.CornerRadius="4"
                                HorizontalAlignment="Stretch" Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Camera" Margin="0,0,8,0"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Capture Frame" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding TestOcrCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                materialDesign:ButtonAssist.CornerRadius="4"
                                HorizontalAlignment="Stretch" Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="TestTube" Margin="0,0,8,0"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Test OCR" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Command="{Binding SaveProfileCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="4">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ContentSave" Margin="0,0,6,0"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Save" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2"
                                    Command="{Binding DeleteProfileCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="#EF5350"
                                    materialDesign:ButtonAssist.CornerRadius="4">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Delete" Margin="0,0,6,0"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Delete" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <!-- Test Result -->
                    <Border Background="#1A1A2E" CornerRadius="4"
                            Padding="8" Margin="0,8,0,0"
                            MinHeight="40">
                        <TextBlock Text="{Binding TestResult}" FontSize="11"
                                   TextWrapping="Wrap" Opacity="0.8" />
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </materialDesign:Card>
    </Grid>
</UserControl>
