<UserControl x:Class="OnAirCut.Recorder.Views.PreviewPlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
             xmlns:vm="clr-namespace:OnAirCut.Recorder.ViewModels"
             xmlns:converters="clr-namespace:OnAirCut.Recorder.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:PreviewPlayerViewModel}">

    <UserControl.Resources>
        <converters:TimeSpanToStringConverter x:Key="TimeSpanToString" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Video Preview Area -->
        <Border Grid.Row="0" Background="#1A1A2E" CornerRadius="4" Margin="4">
            <Grid>
                <!-- Placeholder when no source -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding HasSource, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                    <materialDesign:PackIcon Kind="VideoOff" Width="64" Height="64"
                                             HorizontalAlignment="Center"
                                             Foreground="#555" />
                    <TextBlock Text="No video source connected"
                               FontSize="14" Foreground="#555"
                               HorizontalAlignment="Center" Margin="0,8,0,0" />
                </StackPanel>

                <!-- LibVLC VideoView -->
                <vlc:VideoView x:Name="VlcVideoView"
                               Visibility="{Binding HasSource, Converter={StaticResource BoolToVisibility}}" />

                <!-- VU Meters (right side overlay) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Bottom" Margin="0,0,8,8"
                            Visibility="{Binding HasSource, Converter={StaticResource BoolToVisibility}}">
                    <Border Width="8" Height="80" Background="#333" CornerRadius="2" Margin="2,0">
                        <Border CornerRadius="2" VerticalAlignment="Bottom"
                                Height="{Binding LeftLevel, Converter={x:Static converters:LevelToHeightConverter.Instance}}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                    <GradientStop Color="#66BB6A" Offset="0" />
                                    <GradientStop Color="#FFCA28" Offset="0.7" />
                                    <GradientStop Color="#EF5350" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Border>
                    <Border Width="8" Height="80" Background="#333" CornerRadius="2" Margin="2,0">
                        <Border CornerRadius="2" VerticalAlignment="Bottom"
                                Height="{Binding RightLevel, Converter={x:Static converters:LevelToHeightConverter.Instance}}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                    <GradientStop Color="#66BB6A" Offset="0" />
                                    <GradientStop Color="#FFCA28" Offset="0.7" />
                                    <GradientStop Color="#EF5350" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Timecode and Seek Bar -->
        <Grid Grid.Row="1" Margin="8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding CurrentPosition, Converter={StaticResource TimeSpanToString}}"
                       FontFamily="Consolas" FontSize="12"
                       VerticalAlignment="Center" Opacity="0.8" />

            <Slider Grid.Column="1" Margin="8,0"
                    Minimum="0" Maximum="100"
                    Value="{Binding SeekPosition}"
                    VerticalAlignment="Center" />

            <TextBlock Grid.Column="2"
                       Text="{Binding Duration, Converter={StaticResource TimeSpanToString}}"
                       FontFamily="Consolas" FontSize="12"
                       VerticalAlignment="Center" Opacity="0.8" />
        </Grid>

        <!-- Transport Controls -->
        <Grid Grid.Row="2" Margin="8,0,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Speed Controls -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Speed:" FontSize="11" VerticalAlignment="Center"
                           Margin="0,0,6,0" Opacity="0.7" />
                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Padding="4,2" MinWidth="0"
                        Command="{Binding ChangeSpeedCommand}" CommandParameter="0.5"
                        Content="0.5x" FontSize="10" />
                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Padding="4,2" MinWidth="0"
                        Command="{Binding ChangeSpeedCommand}" CommandParameter="1.0"
                        Content="1x" FontSize="10" />
                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Padding="4,2" MinWidth="0"
                        Command="{Binding ChangeSpeedCommand}" CommandParameter="1.5"
                        Content="1.5x" FontSize="10" />
                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Padding="4,2" MinWidth="0"
                        Command="{Binding ChangeSpeedCommand}" CommandParameter="2.0"
                        Content="2x" FontSize="10" />
            </StackPanel>

            <!-- Play/Pause -->
            <Button Grid.Column="1"
                    Style="{StaticResource MaterialDesignIconForegroundButton}"
                    Command="{Binding PlayPauseCommand}"
                    Width="48" Height="48">
                <materialDesign:PackIcon Width="32" Height="32">
                    <materialDesign:PackIcon.Style>
                        <Style TargetType="materialDesign:PackIcon">
                            <Setter Property="Kind" Value="PlayArrow" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                    <Setter Property="Kind" Value="Pause" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </materialDesign:PackIcon.Style>
                </materialDesign:PackIcon>
            </Button>

            <!-- Volume Controls -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{StaticResource MaterialDesignIconButton}"
                        Command="{Binding ToggleMuteCommand}"
                        Width="28" Height="28">
                    <materialDesign:PackIcon Width="18" Height="18">
                        <materialDesign:PackIcon.Style>
                            <Style TargetType="materialDesign:PackIcon">
                                <Setter Property="Kind" Value="VolumeHigh" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMuted}" Value="True">
                                        <Setter Property="Kind" Value="VolumeOff" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </materialDesign:PackIcon.Style>
                    </materialDesign:PackIcon>
                </Button>
                <Slider Minimum="0" Maximum="100" Width="80"
                        Value="{Binding Volume}"
                        VerticalAlignment="Center"
                        Margin="4,0,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
